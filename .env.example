# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Open WebUI ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# ── Anthropic / Claude API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── n8n ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Hostname n8n will use for webhooks (set to your Tailscale machine name for remote access)
# e.g. N8N_HOST=ezra.tail1234.ts.net
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Timezone for n8n scheduler (IANA format)
TIMEZONE=America/New_York

# ── Tailscale ──────────────────────────────────────────────────────────────
# Generate a reusable/ephemeral auth key at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Optional extra args passed to tailscaled (e.g. --advertise-tags=tag:server)
TS_EXTRA_ARGS=
